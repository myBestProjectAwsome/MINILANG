    (8) statement -> . IF expression LBRACE statement_list RBRACE ELSE LBRACE statement_list RBRACE
    (9) statement -> . WHILE expression LBRACE statement_list RBRACE

    RBRACE          shift and go to state 54
    LET             shift and go to state 4
    IDENTIFIER      shift and go to state 5
    PRINT           shift and go to state 6
    IF              shift and go to state 7
    WHILE           shift and go to state 8

    statement                      shift and go to state 9

state 54

    (8) statement -> IF expression LBRACE statement_list RBRACE ELSE LBRACE statement_list RBRACE .

    LET             reduce using rule 8 (statement -> IF expression LBRACE statement_list RBRACE ELSE LBRACE statement_list RBRACE .)
