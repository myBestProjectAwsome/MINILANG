Created by PLY version 3.11 (http://www.dabeaz.com/ply)

Grammar

Rule 0     S' -> program
Rule 1     program -> statement_list
Rule 2     statement_list -> statement_list statement
Rule 3     statement_list -> statement
Rule 4     statement -> LET IDENTIFIER ASSIGN expression
Rule 5     statement -> PRINT LPAREN expression RPAREN
Rule 6     expression -> INTEGER
Rule 7     expression -> IDENTIFIER

Terminals, with rules where they appear

ASSIGN               : 4
IDENTIFIER           : 4 7
INTEGER              : 6
LET                  : 4
LPAREN               : 5
PRINT                : 5
RPAREN               : 5
error                : 

Nonterminals, with rules where they appear

expression           : 4 5
program              : 0
statement            : 2 3
statement_list       : 1 2

Parsing method: LALR

state 0

    (0) S' -> . program
    (1) program -> . statement_list
    (2) statement_list -> . statement_list statement
    (3) statement_list -> . statement
    (4) statement -> . LET IDENTIFIER ASSIGN expression
    (5) statement -> . PRINT LPAREN expression RPAREN

    LET             shift and go to state 4
    PRINT           shift and go to state 5

    program                        shift and go to state 1
    statement_list                 shift and go to state 2
    statement                      shift and go to state 3

state 1

    (0) S' -> program .



state 2

    (1) program -> statement_list .
    (2) statement_list -> statement_list . statement
    (4) statement -> . LET IDENTIFIER ASSIGN expression
    (5) statement -> . PRINT LPAREN expression RPAREN

    $end            reduce using rule 1 (program -> statement_list .)
    LET             shift and go to state 4
    PRINT           shift and go to state 5

    statement                      shift and go to state 6

state 3

    (3) statement_list -> statement .

    LET             reduce using rule 3 (statement_list -> statement .)
    PRINT           reduce using rule 3 (statement_list -> statement .)
    $end            reduce using rule 3 (statement_list -> statement .)


state 4

    (4) statement -> LET . IDENTIFIER ASSIGN expression

    IDENTIFIER      shift and go to state 7


state 5

    (5) statement -> PRINT . LPAREN expression RPAREN

    LPAREN          shift and go to state 8


state 6

    (2) statement_list -> statement_list statement .

    LET             reduce using rule 2 (statement_list -> statement_list statement .)
    PRINT           reduce using rule 2 (statement_list -> statement_list statement .)
    $end            reduce using rule 2 (statement_list -> statement_list statement .)


state 7

    (4) statement -> LET IDENTIFIER . ASSIGN expression

    ASSIGN          shift and go to state 9


state 8

    (5) statement -> PRINT LPAREN . expression RPAREN
    (6) expression -> . INTEGER
    (7) expression -> . IDENTIFIER

    INTEGER         shift and go to state 11
    IDENTIFIER      shift and go to state 12

    expression                     shift and go to state 10

state 9

    (4) statement -> LET IDENTIFIER ASSIGN . expression
    (6) expression -> . INTEGER
    (7) expression -> . IDENTIFIER

    INTEGER         shift and go to state 11
    IDENTIFIER      shift and go to state 12

    expression                     shift and go to state 13

state 10

    (5) statement -> PRINT LPAREN expression . RPAREN

    RPAREN          shift and go to state 14


state 11

    (6) expression -> INTEGER .

    RPAREN          reduce using rule 6 (expression -> INTEGER .)
    LET             reduce using rule 6 (expression -> INTEGER .)
    PRINT           reduce using rule 6 (expression -> INTEGER .)
    $end            reduce using rule 6 (expression -> INTEGER .)


state 12

    (7) expression -> IDENTIFIER .

    RPAREN          reduce using rule 7 (expression -> IDENTIFIER .)
    LET             reduce using rule 7 (expression -> IDENTIFIER .)
    PRINT           reduce using rule 7 (expression -> IDENTIFIER .)
    $end            reduce using rule 7 (expression -> IDENTIFIER .)


state 13

    (4) statement -> LET IDENTIFIER ASSIGN expression .

    LET             reduce using rule 4 (statement -> LET IDENTIFIER ASSIGN expression .)
    PRINT           reduce using rule 4 (statement -> LET IDENTIFIER ASSIGN expression .)
    $end            reduce using rule 4 (statement -> LET IDENTIFIER ASSIGN expression .)


state 14

    (5) statement -> PRINT LPAREN expression RPAREN .

    LET             reduce using rule 5 (statement -> PRINT LPAREN expression RPAREN .)
    PRINT           reduce using rule 5 (statement -> PRINT LPAREN expression RPAREN .)
    $end            reduce using rule 5 (statement -> PRINT LPAREN expression RPAREN .)

