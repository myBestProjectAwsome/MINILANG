    (2) statement_list -> . statement_list statement
    (3) statement_list -> . statement
    (4) statement -> . LET IDENTIFIER ASSIGN expression
    (5) statement -> . IDENTIFIER ASSIGN expression
    (6) statement -> . PRINT LPAREN expression RPAREN
    (7) statement -> . IF expression LBRACE statement_list RBRACE
    (8) statement -> . IF expression LBRACE statement_list RBRACE ELSE LBRACE statement_list RBRACE
    (9) statement -> . WHILE expression LBRACE statement_list RBRACE

